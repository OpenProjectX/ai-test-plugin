<idea-plugin>
    <id>org.openprojectx.aitestgen</id>
    <name>AI Test Generator</name>
    <vendor>OpenProjectX</vendor>
    <description>AI Test Generator driven by AI, empowering TDD, first classs support for contract based testing </description>


    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <editorNotificationProvider implementation="org.openprojectx.ai.plugin.OpenApiEditorNotificationProvider"/>
        <projectConfigurable instance="org.openprojectx.ai.plugin.AiTestSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <notificationGroup
                id="OpenProjectX Notifications"
                displayType="BALLOON"
                isLogByDefault="true"/>
    </extensions>

    <actions>
        <action
                id="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                class="org.openprojectx.ai.plugin.GenerateCommitMessageAction"
                text="Generate Commit Message"
                description="Generate commit message from current git diff using AI">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeDiffViewerToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeDiffViewerToolbarAction"
                text="Summarize [Probe Diff.ViewerToolbar]"
                description="Summarize [Probe Diff.ViewerToolbar]">
            <add-to-group group-id="Diff.ViewerToolbar" anchor="after" relative-to-action="Diff.ShowSettingsPopup"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeVcsDiffToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeVcsDiffToolbarAction"
                text="Summarize [Probe Vcs.Diff.Toolbar]"
                description="Summarize [Probe Vcs.Diff.Toolbar]">
            <add-to-group group-id="Vcs.Diff.Toolbar" anchor="after" relative-to-action="Diff.ShowSettingsPopup"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeChangesViewToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeChangesViewToolbarAction"
                text="Summarize [Probe ChangesViewToolbar]"
                description="Summarize [Probe ChangesViewToolbar]">
            <add-to-group group-id="ChangesViewToolbar" anchor="after" relative-to-action="ChangesView.ViewOptions"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeVcsLogInternalToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeVcsLogInternalToolbarAction"
                text="Summarize [Probe Vcs.Log.Toolbar.Internal]"
                description="Summarize [Probe Vcs.Log.Toolbar.Internal]">
            <add-to-group group-id="Vcs.Log.Toolbar.Internal" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeVcsLogToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeVcsLogToolbarAction"
                text="Summarize [Probe Vcs.Log.Toolbar]"
                description="Summarize [Probe Vcs.Log.Toolbar]">
            <add-to-group group-id="Vcs.Log.Toolbar" anchor="after" relative-to-action="Vcs.Log.Refresh"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeDiffToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeDiffToolbarAction"
                text="Summarize [Probe Diff.Toolbar]"
                description="Summarize [Probe Diff.Toolbar]">
            <add-to-group group-id="Diff.Toolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeDiffEditorToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeDiffEditorToolbarAction"
                text="Summarize [Probe Diff.EditorToolbar]"
                description="Summarize [Probe Diff.EditorToolbar]">
            <add-to-group group-id="Diff.EditorToolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeFileHistoryToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeFileHistoryToolbarAction"
                text="Summarize [Probe Vcs.FileHistory.Toolbar]"
                description="Summarize [Probe Vcs.FileHistory.Toolbar]">
            <add-to-group group-id="Vcs.FileHistory.Toolbar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeGitBranchesToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeGitBranchesToolbarAction"
                text="Summarize [Probe Git.Branches.ToolBar]"
                description="Summarize [Probe Git.Branches.ToolBar]">
            <add-to-group group-id="Git.Branches.ToolBar" anchor="last"/>
        </action>
        <action
                id="org.openprojectx.ai.plugin.SummarizeProbeCommitMessageToolbarAction"
                class="org.openprojectx.ai.plugin.SummarizeProbeCommitMessageToolbarAction"
                text="Summarize [Probe Vcs.MessageActionGroup]"
                description="Summarize [Probe Vcs.MessageActionGroup]">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
